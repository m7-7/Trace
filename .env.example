# Copy this file to .env and fill in the values.
# .env is never committed — it is listed in .gitignore.

# ── Required ───────────────────────────────────────────────────────────────────

# Session secret — must be a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── Optional ───────────────────────────────────────────────────────────────────

# Path to the SQLite database file.
# Default: ./data/trace.db (relative to working directory)
# Docker Compose sets this to /app/data/trace.db automatically — do not set it
# here when running with Docker unless you want to override that.
# DATABASE_PATH=./data/trace.db
