# Copy this file to .env and fill in the values.
# .env is never committed — it is listed in .gitignore.

# ── Required for Docker Compose ───────────────────────────────────────────────

# Session secret — must be a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── Required for local development only (npm run dev, without Docker) ─────────
# Not needed when running via Docker Compose — the compose file sets this itself.

# DATABASE_URL=postgresql://user:password@localhost:5432/trace
